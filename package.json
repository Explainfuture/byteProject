{
  "name": "byteproject",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "build": "npm run build -ws --if-present",
    "typecheck": "npm run build -ws --if-present",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "concurrently": "^8.2.2",
    "playwright": "^1.60.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
