# App
NODE_ENV=development
APP_PORT=3000
API_PORT=8787
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8787

# Storage
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
TMP_DIR=./data/tmp
MAX_UPLOAD_MB=512
ALLOWED_VIDEO_EXTENSIONS=mp4,mov,webm,mkv
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp

# FFmpeg / Video Processing
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
ENABLE_VISION_ANALYSIS=true
VISION_MIN_FRAME_COUNT=4
VISION_MAX_FRAME_COUNT=16
VISION_SECONDS_PER_FRAME=4

# LLM Provider
# Replace these with your own valid credentials.
LLM_PROVIDER=ark
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=replace_me
ARK_MODEL=Doubao-Seed-2.0-lite
ARK_ENDPOINT_ID=replace_me
ENABLE_AGENT_TOOL_CALLING=true
ALLOW_LOCAL_RULE_FALLBACK=false

# Demo / Fallback
ENABLE_MOCK_GENERATION=true

# Security
DISABLE_REMOTE_URL_UPLOAD=true
