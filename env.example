# App
NODE_ENV=development
APP_PORT=3000
API_PORT=8787
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8787

# Storage
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
TMP_DIR=./data/tmp
MAX_UPLOAD_MB=512
ALLOWED_VIDEO_EXTENSIONS=mp4,mov,webm,mkv
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp

# FFmpeg / Video Processing
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
ENABLE_SCENE_DETECTION=true
SCENE_DETECTION_THRESHOLD=0.35
ENABLE_VISION_ANALYSIS=true
VISION_MIN_FRAME_COUNT=4
VISION_MAX_FRAME_COUNT=16
VISION_SECONDS_PER_FRAME=4

# LLM Provider
# Replace these with your own valid credentials.
LLM_PROVIDER=ark
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=replace_me
ARK_MODEL=Doubao-Seed-2.0-lite
ARK_ENDPOINT_ID=replace_me

# Optional OpenAI-compatible fallback
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini

# ASR
ASR_PROVIDER=mock
ASR_API_KEY=replace_me
ASR_MODEL=replace_me

# AIGC Completion
ENABLE_AIGC_COMPLETION=false
IMAGE_GEN_PROVIDER=mock
IMAGE_GEN_API_KEY=replace_me
TTS_PROVIDER=mock
TTS_API_KEY=replace_me

# Demo / Fallback
ENABLE_MOCK_ANALYSIS=true
ENABLE_MOCK_GENERATION=true

# Security
DISABLE_REMOTE_URL_UPLOAD=true
PRESERVE_SAMPLE_CONTENT=false
LOG_MODEL_PROMPTS=false
LOG_MODEL_RESPONSES=false
